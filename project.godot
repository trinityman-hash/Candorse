; Engine configuration file.
; Godot 4.x — Spatial Video Editor (Candorse)

config_version=5

[application]

config/name="Candorse"
config/description="A video editor built inside a 3D world."
run/main_scene="res://scenes/editor_main.tscn"
config/features=PackedStringArray("4.2", "Mobile")
; config/icon and boot_splash/image intentionally unset: they previously
; pointed at res://assets/branding/candorse_icon.png and candorse_splash.png,
; neither of which exist anywhere in this repo. A dangling icon path throws
; console errors on every boot and, worse, can fail Android/iOS export
; presets outright since those exporters pull the launcher icon from this
; setting and expect a real file. Add real branding assets under
; assets/branding/ and re-point these two keys when they exist — don't
; re-add the path without the file landing in the same commit.
boot_splash/bg_color=Color(0.043, 0.043, 0.043, 1)
boot_splash/fullsize=false
boot_splash/use_filter=true

[rendering]

renderer/rendering_method="mobile"
renderer/rendering_method.mobile="mobile"
textures/vram_compression/import_etc2_astc=true
anti_aliasing/quality/msaa_3d=1

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/handheld/orientation="portrait"
window/stretch/mode="canvas_items"

[physics]

common/enable_pause_aware_picking=true

[autoload]

TimelineData="*res://scripts/timeline/timeline_data.gd"
